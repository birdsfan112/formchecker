# SSL certificates and private keys — NEVER commit
*.pem

# Large media files — too big for git (GitHub 100 MB limit)
*.mov
*.mp4
*.avi
*.mkv

# Claude Code session data
.claude/

# Temp files
*.tmp

# Node / test caches (defensive — FormChecker has no deps but tests.js runs via node)
node_modules/
.pytest_cache/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Environment / secrets
.env

# Logs
*.log

# OS junk
.DS_Store
Thumbs.db
